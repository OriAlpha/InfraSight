# ─── Upstream Provider Configuration ────────────────────────────────
# InfraSight works with any OpenAI-compatible provider.
# Set these to point at your provider of choice.

# Provider name (used in DB records and UI). Examples: deepinfra, openai, openrouter, ollama
# Default: deepinfra
# UPSTREAM_PROVIDER=deepinfra

# Base URL of the upstream API.
# Default: https://api.deepinfra.com
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
# UPSTREAM_API_BASE=https://api.deepinfra.com

# API key for the upstream provider.
# Falls back to DEEPINFRA_API_KEY if not set.
# UPSTREAM_API_KEY=your_api_key_here

# Legacy DeepInfra-specific key (still supported as fallback)
DEEPINFRA_API_KEY=your_deepinfra_api_key_here

# ─── Evaluator Configuration (optional) ────────────────────────────
# Override the model and endpoint used for LLM-as-a-Judge evaluation.
# By default, the evaluator uses the same upstream provider.
# EVALUATOR_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# EVALUATOR_API_BASE=https://api.deepinfra.com/v1/openai/chat/completions

# ─── Server Configuration ──────────────────────────────────────────
PORT=3000
DB_PATH=./data/infrasight.db

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# ─── Dashboard Security (Basic Auth) ───────────────────────────────
# Enable to require authentication for the dashboard UI.
# Proxy routes (/api/proxy) and health checks remain unsecured.
# DASHBOARD_AUTH_ENABLED=false
# DASHBOARD_USERNAME=admin
# DASHBOARD_PASSWORD=your_strong_password

# ─── Privacy & Payload Logging ─────────────────────────────────────
# Set to false to disable logging raw prompt messages and output responses in DB.
# LOG_PAYLOADS=true

# Enable recursive PII masking (emails, phones, credit cards) in stored logs.
# MASK_PII=false

# ─── Guardrails Configuration ─────────────────────────────────────
# Enable active in-transit PII redaction (rewrites messages BEFORE sending to upstream LLM).
# ACTIVE_PII_REDACTION=false

# Comma-separated list of banned keywords. Requests containing these words are blocked.
# BANNED_KEYWORDS=exploit,jailbreak,bypass,malware,hack,ddos

# ─── Webhook Alerts ────────────────────────────────────────────────
# Webhook URLs for real-time alerting notifications.
# ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# ALERT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# Latency threshold in milliseconds. Requests taking longer than this will trigger alerts.
# ALERT_LATENCY_THRESHOLD_MS=5000

# Send notifications when proxy requests encounter failures. Default: true.
# ALERT_ON_FAILURE=true

# ─── Database & Concurrency ───────────────────────────────────────
# PostgreSQL connection URL (optional). If set, InfraSight uses PostgreSQL instead of SQLite.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/infrasight

# Number of concurrent evaluations the background worker executes. Default: 3.
# EVALUATION_CONCURRENCY=3
